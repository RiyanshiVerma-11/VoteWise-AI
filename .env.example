# Google Gemini API Key (Get it from https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSy...

# Google Cloud Services (Enable these in Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_maps_api_key_here
GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here
GOOGLE_TTS_API_KEY=your_tts_api_key_here

# Google OAuth Credentials (Get them from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# App Settings
SECRET_KEY=generate_a_random_secret_key_here
ENVIRONMENT=development
LOG_LEVEL=INFO
